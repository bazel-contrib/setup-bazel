  "license": "MIT",
  "dependencies": {
    "@actions/cache": "^6.0.0",
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@actions/glob": "^0.6.0",
    "@actions/tool-cache": "^4.0.0",
    "esbuild": "^0.27.4",
    "yaml": "^2.2.1"
  }
}
