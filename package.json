{
  "name": "setup-bazel",
  "version": "0.18.0",
  "description": "Install and configure Bazel for GitHub Actions",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "esbuild index.js --bundle --platform=node --format=esm --outfile=dist/main/index.js --sourcemap && esbuild post.js --bundle --platform=node --format=esm --outfile=dist/post/index.js --sourcemap",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
